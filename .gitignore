# Environment files
.env
.env.*
*.env
# …but DO track the sample so others can copy it
!.env.example

# Local development overrides
*.local
*.dev

# Secrets
*.key
*.pem
# Python build artifacts
__pycache__/
*.pyc
*.pyo

# IDE
.idea/
.vscode/

# Claude worktrees
.claude/worktrees/

# OS / tooling cruft
.DS_Store
.coverage
.coverage.*
htmlcov/
nohup.out

# Build artifacts
dist/
build/
*.egg-info/

# Datasets — downloaded on demand, never committed.
# NB: .gitignore has no inline comments — keep patterns on their own lines.
# LOCOMO (make bench-locomo):
evals/locomo/data/
# LongMemEval-S (clone upstream / make repro):
evals/longmemeval/LongMemEval/

# Eval + benchmark run outputs (regenerated; not source)
results/
bench/results/*.json
evals/**/.wiki_cache*/
