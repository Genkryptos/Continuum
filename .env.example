# =============================================================================
# Continuum — sample environment file
# =============================================================================
# Copy to `.env` and fill in what you need:
#
#     cp .env.example .env
#
# `.env` is gitignored. NOTHING here is required for the offline path —
# `make demo-chat`, `make bench-all`, and `make test-fast` all run with zero
# config and no API key. You only need values below for:
#   • the production Postgres path (CONTINUUM_DB_*),
#   • LLM-backed extraction / answering (a provider key),
#   • reproducing the evals (OPENROUTER_API_KEY + the MEM0_* knobs).
#
# Every CONTINUUM_* knob has a sane default; the full list is in docs/config.md.
# Only override what you actually need.
# =============================================================================


# ── LLM provider (pick ONE as your answerer) ─────────────────────────────────
# v1 evals use OpenRouter with openai/gpt-oss-120b. Get a key at openrouter.ai.
OPENROUTER_API_KEY=sk-or-...
# Optional attribution headers OpenRouter shows on your dashboard:
# OPENROUTER_REFERER=https://github.com/Genkryptos/Continuum
# OPENROUTER_TITLE=Continuum

# …or use another provider instead (leave the rest blank):
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_API_KEY=sk-ant-...
# GROQ_API_KEY=gsk_...
# GEMINI_API_KEY=...
# NVIDIA_API_KEY=nvapi-...


# ── PostgreSQL (production path only; not needed for the demo/benchmarks) ─────
# pgvector >= 0.8.0 required. Used by integration tests + the Postgres stores.
# CONTINUUM_DB_DSN=postgresql://postgres:postgres@localhost:5432/continuum
# CONTINUUM_DB_POOL_SIZE=5
# CONTINUUM_DB_TIMEOUT=30


# ── Small LLM (optional: span-fallback + lightweight extraction) ─────────────
# Defaults to a local Ollama at :11434. A `/v1` URL auto-selects the
# OpenAI-compatible backend (LM Studio, vLLM, OpenRouter); override if needed.
# CONTINUUM_SMALL_LLM_URL=http://localhost:11434
# CONTINUUM_SMALL_LLM_MODEL=qwen2.5:1.5b-instruct
# CONTINUUM_SMALL_LLM_BACKEND=ollama          # or: openai
# CONTINUUM_SMALL_LLM_API_KEY=                 # only if the server enforces a bearer


# ── Embeddings (local sentence-transformers; downloaded on first use) ────────
# CONTINUUM_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
# CONTINUUM_EMBED_DEVICE=auto                  # auto | cpu | mps | cuda


# ── Core knobs (all optional) ────────────────────────────────────────────────
# CONTINUUM_ENV=development                    # development | production
# CONTINUUM_LOG_LEVEL=INFO
# CONTINUUM_CONFIG_FILE=continuum.yaml         # load a YAML config instead of env
# CONTINUUM_SCORE_TAU_HOURS=168                # recency half-life (7 days)


# ── Eval reproduction: Mem0 head-to-head (make bench-locomo) ─────────────────
# Mem0's internal extractor must be a NON-reasoning instruct model (reasoning
# models emit truncated JSON). It points at OpenRouter via OPENROUTER_API_KEY.
# MEM0_LLM_MODEL=meta-llama/llama-3.3-70b-instruct
# MEM0_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
# MEM0_EMBED_DIMS=384                          # must match the embed model's size
# MEM0_ADD_CHUNK=20                            # turns per mem0 add() call
